# Celano — Confidential Yield Treasury on Zama
# Copy to .env.local and fill real values. Never commit real secrets.

# --- Frontend (safe to expose; NEXT_PUBLIC_*) ---
# Deployed vault address. Set this to switch the app into LIVE mode automatically
# (otherwise paste it in the UI → Deposit → Vault Address · Sepolia).
# Deployed vault (Sepolia): 0x01eDE7bDA2FaDBf4D83b71337ea4dfA2Ea5e7d37
NEXT_PUBLIC_VAULT_ADDRESS=

# Optional: dedicated Sepolia RPC for the browser (public endpoints rate-limit).
# e.g. https://eth-sepolia.g.alchemy.com/v2/<key>
NEXT_PUBLIC_SEPOLIA_RPC=

# --- Contract deploy (server-side only; keep secret) ---
# Sepolia RPC (use a private one for real load)
SEPOLIA_RPC=https://sepolia.gateway.tenderly.co

# Deployer private key (NEVER commit real keys)
PRIVATE_KEY=0x...

# Optional: Etherscan for verification
ETHERSCAN_API_KEY=

# Zama Relayer (the public one is fine for the demo)
# ZAMA_RELAYER_URL=https://relayer.zama.ai
